generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Device {
  id             String          @id @default(uuid())
  customBinId    String          @unique
  location       String
  fillLevel      Int             @default(0)
  status         String          @default("Active") // Active, Offline, Maintenance
  deviceType     String          @default("bin")
  lastSortedItem String?         
  updatedAt      DateTime        @updatedAt
  createdAt      DateTime        @default(now())
  collectionJobs CollectionJob[]
  processedItems ProcessedItem[]
  deviceEvents   DeviceEvent[]
  alerts         Alert[]

  // Facility link
  facilityId     String?
  facility       Facility?       @relation(fields: [facilityId], references: [id])

  @@index([status])
}

model CollectionJob {
  id          String   @id @default(uuid())
  status      String   @default("Pending") // Pending, In Progress, Completed
  priority    String   @default("Normal")  // Normal, High, Urgent
  wasteType   String   @default("MIXED")
  createdAt   DateTime @default(now())

  // Connecting the job to a specific device
  device      Device   @relation(fields: [deviceId], references: [id])
  deviceId    String

  // Connecting this to a User (Collector)
  collectorId String?  
  collector   User?    @relation(fields: [collectorId], references: [id])
}

// Unified User model for both Managers and Collectors
model User {
  id               String   @id @default(uuid())
  authId           String?  @unique // Supabase auth.users.id
  email            String   @unique
  name             String
  role             String   // e.g. "MANAGER", "COLLECTOR", "ADMIN", "THIRD_PARTY_COLLECTOR"
  status           String   @default("ACTIVE")
  avatar           String?
  assignedFacility String?
  region           String?
  rating           Float?   @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  collectionJobs      CollectionJob[] // For collectors
  bulkCollectionJobs  BulkCollectionJob[] // For third-party collectors

  facilityId          String?
  facility            Facility?           @relation(fields: [facilityId], references: [id])
}

model Facility {
  id                String              @id @default(uuid())
  name              String              @unique // e.g. "Austin Hub"
  region            String?             // e.g. "North Sector"
  status            String              @default("Active") // Active, Offline, Maintenance
  latitude          Float               // Map Latitude coord
  longitude         Float               // Map Longitude coord
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  devices           Device[]
  users             User[]
  bulkJobs          BulkCollectionJob[]
}

model BulkCollectionJob {
  id            String    @id @default(uuid())
  facilityId    String
  facility      Facility  @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  status        String    @default("Pending") // Pending, Dispatched, Completed
  tonnage       Float     // Total accumulated tonnage to collect (e.g. 4.2 Tons)
  collectorName String    // Name of the third-party company (e.g., "Zoomlion", "Jekora Ventures")
  collectorId   String?   // References the Third-Party Collector user
  collector     User?     @relation(fields: [collectorId], references: [id])
  scheduledFor  DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
}

model Feedback {
  id        String   @id @default(uuid())
  userName  String?
  location  String?
  status    String   @default("Pending")
  message   String
  category  String
  createdAt DateTime @default(now())
}

// Telemetry of sorted and rejected items
model ProcessedItem {
  id              String   @id @default(uuid())
  deviceId        String
  category        String   // Plastic, Paper, Metal, Glass, Organic, Other
  status          String   // Sorted, Rejected
  rejectionReason String?  // BIOHAZARD, MEDICAL_WASTE, E_WASTE, BATTERY_LITHIUM
  confidence      Float
  imageUrl        String?
  actionTaken     String
  createdAt       DateTime @default(now())

  device          Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@index([category, status])
}

// System notifications and alerts
model Alert {
  id          String   @id @default(uuid())
  deviceId    String
  severity    String   // CRITICAL, WARNING, INFO
  title       String
  description String
  status      String   @default("Active") // Active, Read, Resolved
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([severity, createdAt])
  @@index([deviceId, createdAt])
  @@index([createdAt])
}

// System, maintenance, and operational events
model DeviceEvent {
  id          String   @id @default(uuid())
  deviceId    String
  eventType   String   // e.g., "POWER CYCLE", "NETWORK SYNC", "SENSOR UPDATE", "MAINTENANCE"
  description String
  severity    String   @default("INFO") // INFO, WARNING, CRITICAL
  createdAt   DateTime @default(now())

  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  actorName String
  details   String
  color     String   @default("text-foreground")
  createdAt DateTime @default(now())
}

