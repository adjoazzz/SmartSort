generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Device {
  id             String          @id @default(uuid())
  customBinId    String          @unique
  location       String
  fillLevel      Int             @default(0)
  status         String          @default("Active")
  lastSortedItem String?
  updatedAt      DateTime        @updatedAt
  createdAt      DateTime        @default(now())
  deviceType     String          @default("bin")
  Alert          Alert[]
  collectionJobs CollectionJob[]
  ProcessedItem  ProcessedItem[]
}

model CollectionJob {
  id          String     @id @default(uuid())
  status      String     @default("Pending")
  priority    String     @default("Normal")
  createdAt   DateTime   @default(now())
  deviceId    String
  collectorId String?
  wasteType   String     @default("MIXED")
  Collector   Collector? @relation(fields: [collectorId], references: [collectorId])
  device      Device     @relation(fields: [deviceId], references: [id])
}

model Collector {
  id            String          @id @default(uuid())
  collectorId   String          @unique
  name          String
  region        String
  status        String          @default("Active")
  rating        Float           @default(0)
  email         String?         @unique
  joinedAt      DateTime        @default(now())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  CollectionJob CollectionJob[]
}

model PlatformUser {
  id               String   @id @default(uuid())
  userId           String   @unique
  name             String
  email            String   @unique
  role             String
  status           String   @default("ACTIVE")
  assignedFacility String
  avatar           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Feedback {
  id        String   @id @default(uuid())
  message   String
  category  String
  createdAt DateTime @default(now())
  location  String
  status    String   @default("Pending")
  userName  String
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Alert {
  id          String   @id
  deviceId    String
  severity    String
  title       String
  description String
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ProcessedItem {
  id              String   @id
  deviceId        String
  category        String
  status          String
  rejectionReason String?
  confidence      Float
  imageUrl        String?
  actionTaken     String
  createdAt       DateTime @default(now())
  Device          Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}
